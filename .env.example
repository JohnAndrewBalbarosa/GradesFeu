GRADES_URL=https://solar.feutech.edu.ph/student/grades
CURRICULUM_URL=https://solar.feutech.edu.ph/program/curriculum

# Honors ranges
HONOR_SUMMA_MIN=3.80
HONOR_SUMMA_MAX=4.00
HONOR_MAGNA_MIN=3.60
HONOR_MAGNA_MAX=3.79
HONOR_CUM_MIN=3.40
HONOR_CUM_MAX=3.59

# Outlier analysis
OUTLIER_METHOD=mad
OUTLIER_TAIL=left
OUTLIER_Z_THRESHOLD=2.5
BASELINE_ESTIMATOR=trimmed_mean
FAILED_GRADE_VALUES=0.0,0.5

# Local cache
CACHE_ENABLED=true
CACHE_FILE=.cache/solar_data.json
